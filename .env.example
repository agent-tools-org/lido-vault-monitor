# Ethereum RPC URL (e.g. Alchemy, Infura, or local node)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Comma-separated depositor addresses to monitor
DEPOSITOR_ADDRESSES=0xYourAddress1,0xYourAddress2

# Poll interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Alert thresholds
APY_SHIFT_THRESHOLD=0.5
TVL_CHANGE_THRESHOLD=10
